# ==============================================================================
# CareerCopilot AI - Backend Environment Config
# ==============================================================================

# Server Configurations
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# Security Configurations
# Replace this secret key in production! Use 'openssl rand -hex 32' to generate one.
JWT_SECRET_KEY=9a6d09f7a75a7c29e6231c5123d46777c9ff7a12b4e870503f8a96d4c1ff00f9
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Allowed CORS Origins (comma-separated strings)
ALLOWED_ORIGINS_STR=http://localhost:3000,https://careercopilot-ai.vercel.app

# Database Configurations
# Replace this with your actual connection string from Supabase
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Supabase Configurations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Services (at least one required for AI analysis)
OPENAI_API_KEY=sk-your-openai-api-key
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
OPENAI_MODEL=gpt-4o

# Job Provider API Keys (optional - falls back to mock data)
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
